{
  "name": "@fastnote/web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "FastNote web frontend",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:e2e:scroll": "cypress run --spec tests/e2e/folder-scroll-restore.cy.ts",
    "test:unit": "vitest",
    "test:p0:unit": "vitest --run tests/unit/stores/notes-delete-subtree.spec.ts tests/unit/hooks/useSync-retry.spec.ts tests/integration/editor/attachment-retry.spec.ts",
    "test:p0:e2e": "cypress run --spec \"tests/e2e/public/public-home-smoke.cy.ts,tests/e2e/public/public-note-detail.cy.ts,tests/e2e/public/public-init-retry.cy.ts\"",
    "test:p0": "npm run test:p0:unit && npm run test:p0:sync-integrity",
    "lint": "eslint .",
    "test:p0:sync-integrity": "vitest --run tests/unit/hooks/useSync-user-scope.spec.ts tests/unit/hooks/useDesktopActiveNote.spec.ts tests/unit/views/note-detail-missing-note.spec.ts tests/unit/views/home-desktop-restore.spec.ts tests/integration/home/desktop-refresh-restore.spec.ts tests/integration/home/desktop-folder-refresh-restore.spec.ts tests/integration/sync/private-route-restore.spec.ts tests/integration/sync/public-home-restore.spec.ts tests/integration/sync/cache-repair.spec.ts"
  },
  "dependencies": {
    "@ionic/vue": "^8.7.9",
    "@ionic/vue-router": "^8.7.9",
    "@tiptap/core": "^3.10.7",
    "@tiptap/extension-color": "^3.10.7",
    "@tiptap/extension-image": "^3.10.7",
    "@tiptap/extension-table": "^3.10.7",
    "@tiptap/extension-text-align": "^3.10.7",
    "@tiptap/extension-text-style": "^3.10.7",
    "@tiptap/extension-underline": "^3.10.7",
    "@tiptap/pm": "^3.10.7",
    "@tiptap/starter-kit": "^3.10.7",
    "@tiptap/vue-3": "^3.10.7",
    "@vueuse/core": "^13.3.0",
    "axios": "^1.13.2",
    "core-js": "^3.42.0",
    "dexie": "^4.0.11",
    "ionicons": "^8.0.13",
    "nanoid": "^5.1.5",
    "photoswipe": "^5.4.4",
    "pocketbase": "^0.26.3",
    "sass": "^1.85.1",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "vconsole": "^3.15.1",
    "vue": "^3.5.24",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@unocss/eslint-plugin": "^66.5.1",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.3.0",
    "cypress": "^13.5.0",
    "eslint": "^9.23.0",
    "eslint-plugin-format": "^1.0.2",
    "eslint-plugin-vue": "^10.4.0",
    "jsdom": "^22.1.0",
    "terser": "^5.4.0",
    "typescript": "~5.6.2",
    "unocss": "^66.5.6",
    "vite": "^7.2.2",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.1.10"
  }
}
