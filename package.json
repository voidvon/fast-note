{
  "name": "fast-note-workspace",
  "private": true,
  "version": "0.1.1-alpha.1",
  "type": "module",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @fastnote/web",
    "build": "npm run build --workspace @fastnote/web",
    "lint": "npm run lint --workspace @fastnote/web",
    "test:unit": "npm run test:unit --workspace @fastnote/web",
    "test:e2e": "npm run test:e2e --workspace @fastnote/web",
    "build:web": "node scripts/package/build-web.mjs",
    "build:launcher": "node scripts/package/build-launcher.mjs",
    "fetch:pocketbase": "node scripts/package/fetch-pocketbase.mjs",
    "build:manifest": "node scripts/package/build-manifest.mjs",
    "release": "node scripts/package/release.mjs"
  }
}
